# Medha mobile — local environment
# Expo loads EXPO_PUBLIC_* at bundle time.
#
# Physical device (Expo Go): use your PC's Wi-Fi IP, NOT localhost.
# Find IP (CMD):  ipconfig | findstr IPv4
#
EXPO_PUBLIC_API_URL=http://192.168.1.44:8000

# Forces Metro QR code to use LAN IP instead of 127.0.0.1 (Windows fix).
# Update when your Wi-Fi IP changes.
REACT_NATIVE_PACKAGER_HOSTNAME=192.168.1.44
